  },
  "dependencies": {
    "@pebble/engine": "workspace:*",
    "@pebble/protocol": "workspace:*",
    "socket.io": "^4.8.3",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "~5.7.2",
    "vitest": "^4.1.10"
  }
}
